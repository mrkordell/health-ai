# Frontend (apps/web)
# VITE_API_URL is not needed - uses relative URLs with Vite proxy in dev
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Backend (apps/api)
PORT=3001
DATABASE_URL=postgresql://healthai:healthai@localhost:5432/healthai
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here
NUTRITIONIX_API_KEY=your_nutritionix_api_key_here
